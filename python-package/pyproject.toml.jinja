[build-system]
requires = ["setuptools"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name }}"
version = "1.0.0"
description = "Description"
readme = "README.md"
requires-python = ">=3.8"
license = "GPL-3.0-or-later"
classifiers = [
    "Programming Language :: Python :: 3"
]
authors = [
    {name = "{{ project_author }}"}
]
dependencies = [
    # your dependencies
]

[project.urls]
Homepage = "https://github.com/{{ project_author }}/{{ project_name }}"
Repository = "https://github.com/{{ project_author }}/{{ project_name }}"
Issues = "https://github.com/{{ project_author }}/{{ project_name }}/issues"

[project.scripts]
{{ project_name }} = "{{ package_name }}.__main__:main"
