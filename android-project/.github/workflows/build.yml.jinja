name: Build
on:
  workflow_dispatch:
    inputs:
      build_type:
        description: Select build type
        default: debug
        type: choice
        options:
          - debug
          - release

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up JDK {{ jvm_toolchain }}
        uses: actions/setup-java@v4
        with:
          distribution: "temurin"
          java-version: "{{ jvm_toolchain }}"
          cache: "gradle"

      - name: Grant execute permission for gradlew
        run: chmod +x gradlew

      - name: Validate Gradle wrapper
        uses: gradle/actions/wrapper-validation@v4

      - name: Decode Keystore
        if: {% raw %}${{ inputs.build_type == 'release' }}{% endraw %}
        run: echo "${{ signing_key }}" | base64 --decode > app/{{ store_file }}
        env:
          {{ signing_key }}: {% raw %}${{ secrets.{% endraw %}{{ signing_key }}{% raw %} }}{% endraw %}

      - name: Build APK
        run: ./gradlew assemble{% raw %}${{ inputs.build_type == 'release' && 'Release' || 'Debug' }}{% endraw %}
        env:
          {{ store_password }}: {% raw %}${{ secrets.{% endraw %}{{ store_password }}{% raw %} }}{% endraw %}
          {{ key_alias }}: {% raw %}${{ secrets.{% endraw %}{{ key_alias }}{% raw %} }}{% endraw %}

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: app-{% raw %}${{ inputs.build_type }}{% endraw %}
          path: {% raw %}${{ inputs.build_type == 'release' && 'app/build/outputs/apk/release/app-release.apk' || 'app/build/outputs/apk/debug/app-debug.apk' }}{% endraw %}

      - name: Extract version
        if: {% raw %}${{ inputs.build_type == 'release' }}{% endraw %}
        id: version
        run: |
          version=$(jq -r '.elements[0].versionName' app/build/outputs/apk/release/output-metadata.json)
          echo "version=$version" >> $GITHUB_OUTPUT

      - name: Create Release
        if: {% raw %}${{ inputs.build_type == 'release' }}{% endraw %}
        uses: svenstaro/upload-release-action@v2
        with:
          file: app/build/outputs/apk/release/app-release.apk
          tag: v{% raw %}${{ steps.version.outputs.version }}{% endraw %}
          asset_name: {{ project_name }}-v{% raw %}${{ steps.version.outputs.version }}{% endraw %}.apk
          release_name: {% raw %}${{ steps.version.outputs.version }}{% endraw %}
          overwrite: true